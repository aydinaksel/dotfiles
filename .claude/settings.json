{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0"
  },
  "permissions": {
    "allow": [
      "Read(~/*)",
      "Bash(git -C * status)",
      "Bash(git -C * diff)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ],
    "ask": [
      "Bash(curl *)"
    ]
  },
  "spinnerTipsEnabled": false,
  "effortLevel": "medium",
  "prefersReducedMotio": true,
  "model": "sonnet"
}
