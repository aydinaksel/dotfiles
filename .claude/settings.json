{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "model": "sonnet",
  "effortLevel": "low",
  "spinnerTipsEnabled": false,
  "prefersReducedMotio": true,
  "permissions": {
    "allow": [
      "Read(~/*)",
      "Bash(git diff *)"
    ],
    "ask": [
      "Bash(curl *)"
    ],
    "deny": [
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ]
  },
  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0"
  }
}
